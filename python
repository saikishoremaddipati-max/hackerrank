---------
 # Step 1: Read the input
n = int(input())  # Number of students
students = []

for _ in range(n):
    name = input()
    grade = float(input())
    students.append([name, grade])

# Step 2: Extract all grades and find the second lowest grade
grades = sorted(set(grade for name, grade in students))

# The second lowest grade is the second item in the sorted unique grades list
second_lowest_grade = grades[1]

# Step 3: Find all students with the second lowest grade
students_with_second_lowest = [name for name, grade in students if grade == second_lowest_grade]

# Step 4: Sort the names alphabetically
students_with_second_lowest.sort()

# Step 5: Print each name on a new line
for student in students_with_second_lowest:
    print(student)
